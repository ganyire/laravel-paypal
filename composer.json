{
	"name": "leonardganyire/paypal",
	"description": "Paypal integration for Laravel",
	"type": "library",
	"version": "1.0.1",
	"keywords": [
		"laravel",
		"paypal",
		"integration",
		"php",
		"payments"
	],
	"license": "MIT",
	"authors": [
		{
			"name": "Leonard Ganyire",
			"email": "ganyirel@gmail.com",
			"role": "Developer"
		}
	],
	"support": {
		"issues": "https://github.com/ganyire/laravel-paypal/issues",
		"email": "ganyirel@gmail.com"
	},
	"require": {
		"php": "^8.3",
		"illuminate/cache": "^11.0|^12.0|^13.0",
		"illuminate/contracts": "^11.0|^12.0|^13.0",
		"illuminate/http": "^11.0|^12.0|^13.0",
		"illuminate/support": "^11.0|^12.0|^13.0"
	},
	"require-dev": {
		"orchestra/testbench": "^11.1",
		"pestphp/pest": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"LeonardGanyire\\Paypal\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"LeonardGanyire\\Paypal\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"LeonardGanyire\\Paypal\\PayPalServiceProvider"
			],
			"aliases": {
				"PayPal": "LeonardGanyire\\Paypal\\Facades\\PayPal"
			}
		}
	},
	"scripts": {
		"test": "@php vendor/bin/pest"
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		},
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
